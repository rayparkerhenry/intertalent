# Copy to .env.local and fill in values:
#   copy .env.example .env.local   (Windows)
#   cp .env.example .env.local     (macOS/Linux)

# Azure SQL
DB_SERVER=ipsql2025.database.windows.net
DB_NAME=intertalent_DB
DB_USER=
DB_PASSWORD=

# Optional table overrides
# AZURE_SQL_PROFILE_TABLE=RayTestShowcase
# AZURE_SQL_LOCATION_EMAIL_TABLE=location_emails

# Email (Office 365 / SMTP) — needed for send-mail features
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
